# =========================================================
# Swiss Solar System Monitor Hub — Environment template
# Copier en .env.local et renseigner avant `npm run dev`
# =========================================================

# --- Base de données Postgres ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL="postgresql://sss:sss@localhost:5432/sss_monitor_hub?schema=public"

# --- Secrets applicatifs ---
# Clé de session JWT (32 octets base64). Générer avec:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SESSION_SECRET="CHANGE_ME_BASE64_32BYTES"

# Clé de chiffrement des tokens fournisseurs (AES-256-GCM, 32 octets base64)
# Générer avec la même commande que ci-dessus.
PROVIDER_TOKEN_ENCRYPTION_KEY="CHANGE_ME_BASE64_32BYTES"

# --- URL publique ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Connecteurs fournisseurs (optionnels en MVP démo) ---
# Enphase Developer — https://developer-v4.enphase.com
ENPHASE_CLIENT_ID=""
ENPHASE_CLIENT_SECRET=""
ENPHASE_API_KEY=""
ENPHASE_REDIRECT_URI="http://localhost:3000/api/providers/enphase/callback"

# Victron VRM — https://vrm.victronenergy.com
VICTRON_VRM_USERNAME=""
VICTRON_VRM_PASSWORD=""
# Ou token bearer si déjà généré
VICTRON_VRM_TOKEN=""

# Fronius Solar.API — local en principe, URL par site configurée dans l'admin
# Pas de clé globale nécessaire.

# Huawei FusionSolar Northbound API
HUAWEI_FUSION_USERNAME=""
HUAWEI_FUSION_PASSWORD=""
HUAWEI_FUSION_API_BASE="https://eu5.fusionsolar.huawei.com"

# --- Mode démo global ---
# Si "true", active une génération de métriques simulées pour les sites qui
# n'ont pas encore de connecteur configuré. Permet la démo commerciale.
ENABLE_GLOBAL_DEMO_MODE="true"

# --- Cron endpoint ---
# Clé partagée pour déclencher /api/sync depuis un scheduler externe (Vercel Cron, etc.)
SYNC_CRON_SECRET="CHANGE_ME_RANDOM_STRING"
